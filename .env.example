# ============================================
# TrocaCromos - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ============================================

# Supabase (obrigatório)
# Crie um projeto em https://supabase.com e cole as chaves abaixo
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TrocaCromos

# Mercado Pago (opcional - para pagamentos Premium)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxx
MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxxxx
MERCADO_PAGO_WEBHOOK_SECRET=

# Admin (e-mails separados por vírgula, com permissão de administração)
ADMIN_EMAILS=admin@trocacromos.com.br
